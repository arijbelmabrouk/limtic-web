# Mot de passe PostgreSQL
DB_PASSWORD=VotreMotDePassePostgres

# Mot de passe SMTP Gmail (App Password Google — 16 caractères sans espaces)
SMTP_USERNAME=votre.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Mot de passe du keystore SSL
SSL_KEYSTORE_PASSWORD=limtic2024
